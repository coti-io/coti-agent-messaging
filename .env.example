# Required for wallet-backed COTI operations, MCP server, and live contract facts:
PRIVATE_KEY=0xyour_private_key
AES_KEY=your_aes_key
CONTRACT_ADDRESS=0xyour_contract_address

# Optional Moltbook auth:
# MOLTBOOK_API_KEY=
# If omitted, the outreach agent will try ~/.config/moltbook/credentials.json

# Optional Moltbook runtime overrides (defaults shown):
# MOLTBOOK_BASE_URL=https://www.moltbook.com/api/v1
# MOLTBOOK_DEFAULT_SUBMOLT=general
# MOLTBOOK_CREDENTIALS_PATH=~/.config/moltbook/credentials.json
# MOLTBOOK_STATE_PATH=./moltbook-outreach-agent/.data/state.json
# MOLTBOOK_HEARTBEAT_REPORT_PATH=./moltbook-outreach-agent/.data/last-heartbeat.json
# MOLTBOOK_DRY_RUN=false
# MOLTBOOK_AUTO_VERIFY=true

# Optional main LLM / OpenRouter config for post-comment-reply generation:
# MOLTBOOK_LLM_API_KEY=
# MOLTBOOK_LLM_MODEL=openai/gpt-4o-mini
# MOLTBOOK_LLM_BASE_URL=https://openrouter.ai/api/v1
# MOLTBOOK_LLM_TIMEOUT_MS=20000
# MOLTBOOK_LLM_APP_NAME=moltbook-outreach-agent
# MOLTBOOK_LLM_SITE_URL=

# Optional OpenRouter alias vars (supported as alternatives):
# OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL=openai/gpt-4o-mini

# Optional verification-only LLM fallback for Moltbook captcha solving:
# MOLTBOOK_VERIFY_LLM_API_KEY=
# If omitted, verification reuses the main LLM/OpenRouter config above.
# MOLTBOOK_VERIFY_LLM_MODEL=openai/gpt-4o-mini
# MOLTBOOK_VERIFY_LLM_BASE_URL=https://openrouter.ai/api/v1
# MOLTBOOK_VERIFY_LLM_TIMEOUT_MS=20000

# Optional COTI network overrides (defaults shown):
# COTI_NETWORK=testnet
# COTI_RPC_URL=
# COTI_TESTNET_RPC_URL=https://your-coti-testnet-rpc
# COTI_MAINNET_RPC_URL=https://your-coti-mainnet-rpc

# Optional contract deploy overrides (defaults shown):
# EPOCH_DURATION_SECONDS=1209600
# INITIAL_REWARD_FUND_WEI=0
# DEPLOY_GAS_LIMIT=12000000
# DEPLOY_GAS_PRICE_WEI=
# DEPLOY_MAX_FEE_PER_GAS_WEI=
# DEPLOY_MAX_PRIORITY_FEE_PER_GAS_WEI=
