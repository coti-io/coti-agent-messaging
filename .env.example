# Required for wallet-backed COTI operations, MCP server, and live contract facts:
PRIVATE_KEY=0xyour_private_key
AES_KEY=your_aes_key
CONTRACT_ADDRESS=0xyour_contract_address
# Optional but recommended for analytics on non-archive RPCs:
# CONTRACT_DEPLOY_BLOCK=123456

# Optional Moltbook auth:
# MOLTBOOK_API_KEY=
# If omitted, the outreach agent will try ~/.config/moltbook/credentials.json

# Optional starter-grant backend for first-time agent funding:
# STARTER_GRANT_SERVICE_URL=http://127.0.0.1:8787
# STARTER_GRANT_SERVICE_TIMEOUT_MS=15000
# STARTER_GRANT_SERVICE_AUTH_TOKEN=
# STARTER_GRANT_INSTALL_ID_PATH=~/.config/coti-agent-messaging/install-state.json

# Starter-grant service runtime:
# STARTER_GRANT_FUNDER_PRIVATE_KEY=0xyour_hot_wallet_private_key
# STARTER_GRANT_RPC_URL=https://testnet.coti.io/rpc
# STARTER_GRANT_AMOUNT_COTI=0.001
# STARTER_GRANT_CHALLENGE_TTL_MS=300000
# STARTER_GRANT_SERVICE_HOST=127.0.0.1
# STARTER_GRANT_SERVICE_PORT=8787
# STARTER_GRANT_SERVICE_STATE_PATH=./starter-grant-service/.data/starter-grants.json
# STARTER_GRANT_MAX_REQUESTS_PER_WINDOW=8
# STARTER_GRANT_RATE_LIMIT_WINDOW_MS=600000

# Optional Moltbook runtime overrides (defaults shown):
# MOLTBOOK_BASE_URL=https://www.moltbook.com/api/v1
# MOLTBOOK_DEFAULT_SUBMOLT=general
# MOLTBOOK_CREDENTIALS_PATH=~/.config/moltbook/credentials.json
# MOLTBOOK_STATE_PATH=./moltbook-outreach-agent/.data/state.json
# MOLTBOOK_HEARTBEAT_REPORT_PATH=./moltbook-outreach-agent/.data/last-heartbeat.json
# MOLTBOOK_DRY_RUN=false
# MOLTBOOK_AUTO_VERIFY=true

# Optional main LLM / OpenRouter config for post-comment-reply generation:
# MOLTBOOK_LLM_API_KEY=
# MOLTBOOK_LLM_MODEL=openai/gpt-4o-mini
# MOLTBOOK_LLM_BASE_URL=https://openrouter.ai/api/v1
# MOLTBOOK_LLM_TIMEOUT_MS=20000
# MOLTBOOK_LLM_APP_NAME=moltbook-outreach-agent
# MOLTBOOK_LLM_SITE_URL=
#
# Optional local bridge for out-of-process providers.
# If set, the outreach agent POSTs { messages } to this URL and expects either:
# - a direct JSON result object, or
# - { "result": <json-result> }
# MOLTBOOK_LLM_BRIDGE_URL=http://127.0.0.1:4318/json-completion
# MOLTBOOK_LLM_BRIDGE_LABEL=local-bridge
# MOLTBOOK_LLM_BRIDGE_TIMEOUT_MS=20000
# MOLTBOOK_LLM_BRIDGE_AUTH_TOKEN=

# Optional OpenRouter alias vars (supported as alternatives):
# OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL=openai/gpt-4o-mini

# Optional verification-only LLM fallback for Moltbook captcha solving:
# MOLTBOOK_VERIFY_LLM_API_KEY=
# If omitted, verification reuses the main LLM/OpenRouter config above.
# MOLTBOOK_VERIFY_LLM_MODEL=openai/gpt-4o-mini
# MOLTBOOK_VERIFY_LLM_BASE_URL=https://openrouter.ai/api/v1
# MOLTBOOK_VERIFY_LLM_TIMEOUT_MS=20000
#
# Optional verification-only local bridge override:
# MOLTBOOK_VERIFY_LLM_BRIDGE_URL=http://127.0.0.1:4318/json-completion
# MOLTBOOK_VERIFY_LLM_BRIDGE_LABEL=local-bridge
# MOLTBOOK_VERIFY_LLM_BRIDGE_TIMEOUT_MS=10000
# MOLTBOOK_VERIFY_LLM_BRIDGE_AUTH_TOKEN=
#
# Optional launch config for the included manual bridge server:
# MOLTBOOK_LLM_BRIDGE_SERVER_HOST=127.0.0.1
# MOLTBOOK_LLM_BRIDGE_SERVER_PORT=4318
# MOLTBOOK_LLM_BRIDGE_SERVER_PATH=/json-completion
# MOLTBOOK_LLM_BRIDGE_SERVER_DIR=./moltbook-outreach-agent/.bridge/llm-bridge
# MOLTBOOK_LLM_BRIDGE_SERVER_AUTH_TOKEN=
# MOLTBOOK_LLM_BRIDGE_SERVER_RESPONSE_TIMEOUT_MS=300000
# MOLTBOOK_LLM_BRIDGE_SERVER_POLL_INTERVAL_MS=500

# Optional COTI network overrides (defaults shown):
# COTI_NETWORK=testnet
# COTI_RPC_URL=
# COTI_TESTNET_RPC_URL=https://your-coti-testnet-rpc
# COTI_MAINNET_RPC_URL=https://your-coti-mainnet-rpc

# Optional analytics dashboard config:
# MOLTBOOK_ANALYTICS_AGENT_ROOT=/home/ubuntu/coti-agent-messaging/agents
# MOLTBOOK_ANALYTICS_HOST=0.0.0.0
# MOLTBOOK_ANALYTICS_PORT=8788
# MOLTBOOK_ANALYTICS_COTI_CACHE_TTL_MS=60000

# Optional contract deploy overrides (defaults shown):
# EPOCH_DURATION_SECONDS=1209600
# INITIAL_REWARD_FUND_WEI=0
# DEPLOY_GAS_LIMIT=12000000
# DEPLOY_GAS_PRICE_WEI=
# DEPLOY_MAX_FEE_PER_GAS_WEI=
# DEPLOY_MAX_PRIORITY_FEE_PER_GAS_WEI=
