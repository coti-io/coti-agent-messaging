{
  "name": "@coti-agent-messaging/analytics-dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "main": "./dist/analytics-dashboard/src/server.js",
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.json && node scripts/copy-public.cjs",
    "start": "node dist/analytics-dashboard/src/server.js",
    "lint": "tsc --noEmit -p tsconfig.json",
    "test": "npm run build && node --test dist/analytics-dashboard/test/*.test.js"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "ethers": "^6.16.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "typescript": "^5.9.3"
  }
}
