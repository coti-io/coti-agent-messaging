{
  "name": "@coti-agent-messaging/contracts",
  "version": "0.1.0",
  "type": "commonjs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/coti-io/coti-agent-messaging.git",
    "directory": "contracts"
  },
  "bugs": {
    "url": "https://github.com/coti-io/coti-agent-messaging/issues"
  },
  "homepage": "https://github.com/coti-io/coti-agent-messaging/tree/main/contracts",
  "scripts": {
    "export:abi": "node ./scripts/export-abi.mjs",
    "generate:types": "npm run export:abi",
    "build": "npm run export:abi",
    "deploy:testnet": "hardhat run --no-compile scripts/deploy.ts --network cotiTestnet",
    "deploy:mainnet": "hardhat run --no-compile scripts/deploy.ts --network cotiMainnet",
    "message-stats:testnet": "ts-node --project tsconfig.json scripts/message-stats.ts --network testnet",
    "message-stats:mainnet": "ts-node --project tsconfig.json scripts/message-stats.ts --network mainnet"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.3.5",
    "hardhat": "^2.28.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@coti-io/coti-contracts": "git+https://github.com/vladi-coti/coti-contracts.git#messaging",
    "@coti-io/coti-ethers": "^1.0.5",
    "@openzeppelin/contracts": "^4.9.6",
    "dotenv": "^16.6.1"
  }
}
