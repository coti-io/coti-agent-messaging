{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "strict": true,
    "types": [
      "node",
      "mocha"
    ],
    "skipLibCheck": true
  },
  "include": [
    "./hardhat.config.ts",
    "./test/**/*.ts",
    "./scripts/**/*.ts"
  ]
}
