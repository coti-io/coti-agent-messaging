{
  "name": "@coti-agent-messaging/moltbook-outreach-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "bin": {
    "coti-moltbook-outreach-agent": "./dist/src/index.js"
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.json",
    "bridge:start": "node dist/src/bridge-server.js",
    "bridge:stop": "node dist/src/bridge-stop.js",
    "engagements": "node dist/src/index.js engagements",
    "heartbeat": "node dist/src/index.js heartbeat",
    "deploy:rsync": "bash ./deploy-rsync.sh",
    "remote:inspect": "bash ./inspect-remote.sh inspect",
    "remote:status": "bash ./inspect-remote.sh status",
    "remote:logs": "bash ./inspect-remote.sh logs",
    "remote:logs:follow": "bash ./inspect-remote.sh follow",
    "remote:run-now": "bash ./inspect-remote.sh run-now",
    "lint": "tsc --noEmit -p tsconfig.json",
    "test": "npm run build && node --test dist/test/*.test.js"
  },
  "dependencies": {
    "@coti-io/coti-sdk-private-messaging": "git+https://github.com/coti-io/coti-sdk-private-messaging.git#main",
    "@coti-io/coti-ethers": "^1.0.5",
    "dotenv": "^16.6.1"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "typescript": "^5.9.3"
  }
}
