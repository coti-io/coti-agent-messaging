{
  "name": "@coti-agent-messaging/outreach-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "bin": {
    "coti-outreach-agent": "./dist/src/index.js"
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.json",
    "bridge:start": "node dist/src/bridge-server.js",
    "bridge:stop": "node dist/src/bridge-stop.js",
    "engagements": "node dist/src/index.js engagements",
    "design-partners": "node dist/src/index.js design-partners",
    "reddit:targets": "node dist/src/index.js reddit-targets",
    "reddit:scan": "node dist/src/index.js reddit-scan",
    "reddit:evaluate": "node dist/src/index.js reddit-evaluate",
    "reddit:publish": "node dist/src/index.js reddit-publish",
    "reddit:browser:install": "npx playwright install chromium",
    "reddit:login": "node dist/src/index.js reddit-browser-login",
    "reddit:login:local": "OUTREACH_REDDIT_BROWSER_STORAGE_STATE_PATH=./.browser/reddit-storage-state.json node dist/src/index.js reddit-browser-login",
    "reddit:browser-worker": "node dist/src/index.js reddit-browser-worker",
    "reddit:browser-worker:local": "OUTREACH_AGENT_VENUE=reddit OUTREACH_AGENT_MODE=approved_autopost OUTREACH_REDDIT_CONTROLLER=browser OUTREACH_REDDIT_BROWSER_STORAGE_STATE_PATH=./.browser/reddit-storage-state.json node dist/src/index.js reddit-browser-worker",
    "attribution:summary": "node dist/src/index.js attribution-summary",
    "message-funnel": "node dist/src/index.js message-funnel",
    "heartbeat": "node dist/src/index.js heartbeat",
    "deploy:rsync": "bash ./deploy-rsync.sh",
    "remote:inspect": "bash ./inspect-remote.sh inspect",
    "remote:status": "bash ./inspect-remote.sh status",
    "remote:logs": "bash ./inspect-remote.sh logs",
    "remote:logs:follow": "bash ./inspect-remote.sh follow",
    "remote:run-now": "bash ./inspect-remote.sh run-now",
    "lint": "tsc --noEmit -p tsconfig.json",
    "test": "npm run build && node --test dist/test/*.test.js"
  },
  "dependencies": {
    "@coti-io/coti-ethers": "^1.0.5",
    "@coti-io/coti-sdk-private-messaging": "github:coti-io/coti-sdk-private-messaging#main",
    "dotenv": "^16.6.1",
    "playwright": "^1.60.0",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "typescript": "^5.9.3"
  }
}
