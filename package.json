{
  "name": "coti-agent-messaging",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "contracts",
    "starter-grant-service",
    "moltbook-outreach-agent"
  ],
  "scripts": {
    "postinstall": "npm run generate:types",
    "generate:types": "npm run generate:types -w contracts",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test -w @coti-agent-messaging/starter-grant-service && npm run test -w @coti-agent-messaging/moltbook-outreach-agent",
    "lint": "npm run lint --workspaces --if-present",
    "deploy:testnet": "npm run deploy:testnet -w contracts",
    "deploy:mainnet": "npm run deploy:mainnet -w contracts",
    "starter-grant:docker:up": "npm run docker:up -w @coti-agent-messaging/starter-grant-service",
    "starter-grant:docker:down": "npm run docker:down -w @coti-agent-messaging/starter-grant-service",
    "starter-grant:deploy:rsync": "npm run deploy:rsync -w @coti-agent-messaging/starter-grant-service",
    "heartbeat": "node moltbook-outreach-agent/dist/src/index.js heartbeat",
    "starter-grant:start": "npm run start -w @coti-agent-messaging/starter-grant-service"
  }
}
