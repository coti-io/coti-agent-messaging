{
  "name": "coti-agent-messaging",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "contracts",
    "starter-grant-service",
    "outreach-agent",
    "analytics-dashboard"
  ],
  "scripts": {
    "postinstall": "npm run generate:types",
    "generate:types": "npm run generate:types -w contracts",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test -w @coti-agent-messaging/starter-grant-service && npm run test -w @coti-agent-messaging/outreach-agent",
    "lint": "npm run lint --workspaces --if-present",
    "deploy:testnet": "npm run deploy:testnet -w contracts",
    "deploy:mainnet": "npm run deploy:mainnet -w contracts",
    "starter-grant:docker:up": "npm run docker:up -w @coti-agent-messaging/starter-grant-service",
    "starter-grant:docker:down": "npm run docker:down -w @coti-agent-messaging/starter-grant-service",
    "starter-grant:deploy:rsync": "npm run deploy:rsync -w @coti-agent-messaging/starter-grant-service",
    "starter-grant:setup-public-host": "npm run setup:public-host -w @coti-agent-messaging/starter-grant-service",
    "outreach:deploy:rsync": "npm run deploy:rsync -w @coti-agent-messaging/outreach-agent",
    "outreach:remote:inspect": "npm run remote:inspect -w @coti-agent-messaging/outreach-agent",
    "outreach:remote:status": "npm run remote:status -w @coti-agent-messaging/outreach-agent",
    "outreach:remote:logs": "npm run remote:logs -w @coti-agent-messaging/outreach-agent",
    "outreach:remote:logs:follow": "npm run remote:logs:follow -w @coti-agent-messaging/outreach-agent",
    "outreach:remote:run-now": "npm run remote:run-now -w @coti-agent-messaging/outreach-agent",
    "outreach:engagements": "npm run engagements -w @coti-agent-messaging/outreach-agent",
    "outreach:reddit:targets": "npm run reddit:targets -w @coti-agent-messaging/outreach-agent",
    "outreach:reddit:scan": "npm run reddit:scan -w @coti-agent-messaging/outreach-agent",
    "outreach:reddit:evaluate": "npm run reddit:evaluate -w @coti-agent-messaging/outreach-agent",
    "outreach:reddit:publish": "npm run reddit:publish -w @coti-agent-messaging/outreach-agent",
    "outreach:reddit:browser:install": "npm run reddit:browser:install -w @coti-agent-messaging/outreach-agent",
    "outreach:reddit:browser:install:deps": "npm run reddit:browser:install:deps -w @coti-agent-messaging/outreach-agent",
    "outreach:reddit:login": "npm run reddit:login -w @coti-agent-messaging/outreach-agent",
    "outreach:reddit:browser-worker": "npm run reddit:browser-worker -w @coti-agent-messaging/outreach-agent",
    "outreach:reddit:browser-worker:stop": "npm run reddit:browser-worker:stop -w @coti-agent-messaging/outreach-agent",
    "outreach:reddit:session:dry-run": "npm run reddit:session:dry-run -w @coti-agent-messaging/outreach-agent",
    "outreach:reddit:dev": "npm run reddit:dev:dry-run -w @coti-agent-messaging/outreach-agent",
    "outreach:reddit:session": "npm run reddit:session -w @coti-agent-messaging/outreach-agent",
    "outreach:reddit:docker:build": "npm run reddit:docker:build -w @coti-agent-messaging/outreach-agent",
    "outreach:reddit:docker:worker": "npm run reddit:docker:worker -w @coti-agent-messaging/outreach-agent",
    "outreach:reddit:docker:session:dry-run": "npm run reddit:docker:session:dry-run -w @coti-agent-messaging/outreach-agent",
    "outreach:reddit:docker:session": "npm run reddit:docker:session -w @coti-agent-messaging/outreach-agent",
    "outreach:reddit:docker:down": "npm run reddit:docker:down -w @coti-agent-messaging/outreach-agent",
    "outreach:attribution:summary": "npm run attribution:summary -w @coti-agent-messaging/outreach-agent",
    "analytics:build": "npm run build -w @coti-agent-messaging/analytics-dashboard",
    "analytics:start": "npm run start -w @coti-agent-messaging/analytics-dashboard",
    "analytics:test": "npm run test -w @coti-agent-messaging/analytics-dashboard",
    "analytics:deploy:rsync": "bash ./deploy-analytics-stack.sh",
    "heartbeat": "node outreach-agent/dist/src/index.js heartbeat",
    "starter-grant:start": "npm run start -w @coti-agent-messaging/starter-grant-service"
  }
}
