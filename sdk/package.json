{
  "name": "@coti-agent-messaging/sdk",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/coti-io/coti-agent-messaging.git",
    "directory": "sdk"
  },
  "bugs": {
    "url": "https://github.com/coti-io/coti-agent-messaging/issues"
  },
  "homepage": "https://github.com/coti-io/coti-agent-messaging/tree/main/sdk",
  "bin": {
    "coti-agent-messaging-mcp": "./dist/server.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "import": "./dist/server.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.test.json",
    "sync:abi": "node ./scripts/sync-abi.mjs",
    "start:mcp": "node ./dist/server.js",
    "test": "npm run build && tsc -p tsconfig.test.json && node --test dist-test/test/*.test.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@coti-io/coti-ethers": "^1.0.5",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "dotenv": "^16.6.1",
    "zod": "^4.3.6"
  }
}
