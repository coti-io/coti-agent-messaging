STARTER_GRANT_FUNDER_PRIVATE_KEY=0xyour_hot_wallet_private_key
STARTER_GRANT_AMOUNT_COTI=0.001

# Optional RPC override. Defaults from `COTI_NETWORK`:
# STARTER_GRANT_RPC_URL=https://testnet.coti.io/rpc
#
# Optional but strongly recommended for public deployment:
STARTER_GRANT_SERVICE_AUTH_TOKEN=replace_me
STARTER_GRANT_SERVICE_HOST=0.0.0.0
STARTER_GRANT_SERVICE_PORT=8787
# Keep the Docker-published port local when nginx is in front:
STARTER_GRANT_SERVICE_BIND_HOST=127.0.0.1
STARTER_GRANT_SERVICE_STATE_PATH=/app/.data/starter-grants.json

# Optional network override. Defaults to `testnet`:
# COTI_NETWORK=testnet

# Optional hardening overrides:
# Set true when requests come through nginx or another reverse proxy:
# STARTER_GRANT_SERVICE_TRUST_PROXY=true
# STARTER_GRANT_SERVICE_MAX_BODY_BYTES=16384
# STARTER_GRANT_CHALLENGE_MAX_REQUESTS_PER_WINDOW=8
# STARTER_GRANT_STATUS_MAX_REQUESTS_PER_WINDOW=8
# STARTER_GRANT_CLAIM_MAX_REQUESTS_PER_WINDOW=4
# STARTER_GRANT_RATE_LIMIT_WINDOW_MS=600000
# STARTER_GRANT_REJECTED_CLAIMS_PER_WINDOW=3
# STARTER_GRANT_REJECTED_CLAIM_WINDOW_MS=900000
# STARTER_GRANT_FUNDING_CONFIRM_TIMEOUT_MS=45000
