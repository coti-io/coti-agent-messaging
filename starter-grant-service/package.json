{
  "name": "@coti-agent-messaging/starter-grant-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.test.json",
    "start": "node ./dist/server.js",
    "test": "npm run build && tsc -p tsconfig.test.json && node --test dist-test/test/*.test.js",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "deploy:rsync": "bash ./deploy-rsync.sh"
  },
  "dependencies": {
    "@coti-io/coti-ethers": "^1.0.5",
    "dotenv": "^16.6.1",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "typescript": "^5.9.3"
  }
}
